# Akiya Japan - Environment Variables Template
# Copy this file to .env and fill in your values
# For Railway deployment, set these via the Railway dashboard or CLI

# ============================================
# Required Variables
# ============================================

# Database (Railway will auto-set this when you add PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database

# Session Secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your_session_secret_here

# ============================================
# API Keys (Required for full functionality)
# ============================================

# OpenAI API (for translations)
OPENAI_API_KEY=sk-...

# ReinfoLib API (for transaction data)
REINFOLIB_API_KEY=...

# GitHub API (for repository operations)
GITHUB_TOKEN=ghp_...

# ============================================
# Partner APIs (Optional)
# ============================================

# LIFULL API
LIFULL_PARTNER_ID=...

# AtHome API
ATHOME_API_KEY=...
ATHOME_CLIENT_ID=...
ATHOME_CLIENT_SECRET=...

# ============================================
# Application Configuration
# ============================================

# Node Environment
NODE_ENV=production

# Port (Railway sets this automatically, but you can override)
PORT=5000

# Logging
LOG_LEVEL=info

# ============================================
# Optional: Monitoring & Error Tracking
# ============================================

# Sentry
SENTRY_DSN=https://...

# ============================================
# Railway-Specific (Auto-set by Railway)
# ============================================

# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app
# RAILWAY_PRIVATE_DOMAIN=your-app.railway.internal
# RAILWAY_SERVICE_NAME=akiya-app
# RAILWAY_PROJECT_NAME=akiya-japan
# RAILWAY_ENVIRONMENT_NAME=production
